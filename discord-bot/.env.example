# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
ALERT_CHANNEL_ID=1234567890123456789

# Supabase PostgreSQL (same DB as the web app)
# Use Session Pooler (port 5432), NOT Direct connection
# Format: postgresql+asyncpg://postgres.{project_ref}:{password}@aws-0-{region}.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Schedule
TIMEZONE=America/Bogota
CHECK_HOUR=7
